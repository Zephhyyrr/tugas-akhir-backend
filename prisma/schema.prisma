generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleUser {
  superadmin
  admin
}

enum TipeTransaksi {
  uang_masuk
  uang_keluar
}

enum TipeKurban {
  individu_sapi
  individu_kambing
  kelompok
}

enum JenisKonten {
  berita
  pengurus
  imsakiyah
  sejarah
}

model User {
  id          Int       @id @default(autoincrement())
  isDeleted   Boolean   @default(false)
  isActive    Boolean   @default(true)
  nama        String
  email       String    @unique
  role        RoleUser
  password    String
  fotoProfile String?
  isVerified  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userToken    UserToken[]
  contents     Content[]
  transactions Transaction[]
  predictions  Prediction[]
}

model UserToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])
}

model Content {
  id        Int         @id @default(autoincrement())
  judul     String
  isi       String      @db.Text
  gambarUrl String
  jenis     JenisKonten
  isTampil  Boolean     @default(true)
  isDeleted Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KelompokKurban {
  id        Int      @id @default(autoincrement())
  nama      String
  tahun     String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  peserta PesertaKurban[]
}

model PesertaKurban {
  id        Int        @id @default(autoincrement())
  nama      String
  nominal   Float
  tahun     String
  tipe      TipeKurban
  isDeleted Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  mediaPembayaranId Int
  mediaPembayaran   MediaPembayaran @relation(fields: [mediaPembayaranId], references: [id])

  kelompokKurbanId Int?
  kelompokKurban   KelompokKurban? @relation(fields: [kelompokKurbanId], references: [id])
}

model JenisKas {
  id        Int      @id @default(autoincrement())
  nama      String   @unique
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
  predictions  Prediction[]
}

model MediaPembayaran {
  id        Int      @id @default(autoincrement())
  nama      String   @unique
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions  Transaction[]
  pesertaKurban PesertaKurban[]
}

model FavoriteTransaksi {
  id        Int      @id @default(autoincrement())
  uraian    String   @unique
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id        Int           @id @default(autoincrement())
  uraian    String
  tipe      TipeTransaksi
  nominal   Float
  debit     Float         @default(0)
  kredit    Float         @default(0)
  tanggal   DateTime
  isDeleted Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  jenisKasId Int
  jenisKas   JenisKas @relation(fields: [jenisKasId], references: [id])

  mediaPembayaranId Int
  mediaPembayaran   MediaPembayaran @relation(fields: [mediaPembayaranId], references: [id])
}

model Prediction {
  id                  Int      @id @default(autoincrement())
  prediksiPemasukan   Float
  prediksiPengeluaran Float
  tanggalTarget       DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  jenisKasId Int
  jenisKas   JenisKas @relation(fields: [jenisKasId], references: [id])
}